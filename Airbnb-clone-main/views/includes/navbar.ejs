<style>
  .search-btn {
    background-color: #fe424d;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 25px;
  }
  .search-btn:hover {
    background-color: #fe424d;
    color: #fff;
  }
  .search-btn i {
    margin: 0;
  }
  .search-inp {
    border-radius: 25px;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid d-flex justify-content-between align-items-center">

    <!-- Left section -->
    <div class="d-flex align-items-center">
      <a class="navbar-brand" href="/listings">
        <i class="fa-solid fa-compass"></i>
      </a>
      <a class="nav-link" href="/listings">Explore</a>
    </div>

    <!-- Center section (Search Bar) -->
    <div class="mx-auto">
      <form class="d-flex" role="search" style="max-width: 400px">
        <input
          class="form-control me-2 text-center search-inp"
          type="search"
          placeholder="Search Destination"
          style="border-radius: 25px"
        />
        <button class="btn search-btn" type="submit" style="border-radius: 25px">
          <i class="fa-solid fa-magnifying-glass"></i>
          Search
        </button>
      </form>
    </div>

    <!-- Right section -->
    <div class="navbar-nav d-flex align-items-center">
      <a class="nav-link" href="/listings/new">Airbnb your home</a>
      <% if (!locals.currUser) { %>
        <a class="nav-link fw-semibold" href="/signup">Sign up</a>
        <a class="nav-link fw-semibold" href="/login">Log in</a>
      <% } %>
      <% if (locals.currUser) { %>
        <a class="nav-link fw-semibold" href="/logout">Log out</a>
      <% } %>
    </div>

  </div>
</nav>